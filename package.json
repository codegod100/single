{
  "name": "single",
  "version": "1.0.6",
  "description": "A single-tab Chromium-based browser with extension support.",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-dev-shm-usage",
    "dist": "electron-builder --linux",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.nandi.single",
    "productName": "Single",
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network"
    },
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [],
  "author": "Nandi <nandi@example.com>",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-chrome-extensions": "^4.9.0",
    "node-fetch": "^2.7.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
